{
	"name": "expo-telegram-auth",
	"version": "0.1.0",
	"description": "Native Telegram Login for Expo apps — wraps Telegram's official Android and iOS Login SDKs for a browser-free, app-to-app OAuth flow that returns an OIDC id_token",
	"main": "build/index.js",
	"types": "build/index.d.ts",
	"scripts": {
		"biome": "biome check --write .",
		"build": "expo-module build",
		"build:plugin": "expo-module build plugin",
		"clean": "expo-module clean",
		"expo-module": "expo-module",
		"lint": "expo-module lint",
		"postinstall": "lefthook install || true",
		"prepare": "cross-env EXPO_NONINTERACTIVE=1 expo-module build && cross-env EXPO_NONINTERACTIVE=1 expo-module build plugin",
		"prepublishOnly": "expo-module prepublishOnly",
		"sync-upstream": "node scripts/sync-upstream.mjs"
	},
	"keywords": [
		"react-native",
		"expo",
		"telegram",
		"telegram-login",
		"oauth",
		"oidc",
		"expo-telegram-auth"
	],
	"repository": "https://github.com/stacknide/expo-telegram-auth",
	"bugs": {
		"url": "https://github.com/stacknide/expo-telegram-auth/issues"
	},
	"author": "ashuvssut",
	"license": "MIT",
	"homepage": "https://github.com/stacknide/expo-telegram-auth#readme",
	"files": [
		"android/build.gradle",
		"android/src",
		"app.plugin.js",
		"build",
		"expo-module.config.json",
		"ios",
		"plugin/build",
		"CHANGELOG.md",
		"LICENSE",
		"README.md",
		"THIRD_PARTY_LICENSES.md"
	],
	"telegramSdk": {
		"android": {
			"repository": "https://github.com/TelegramMessenger/telegram-login-android",
			"version": "1.0.0",
			"commit": "1f3fd00a9d4a114f854969f5db61fc8edb1a8dca"
		},
		"ios": {
			"repository": "https://github.com/TelegramMessenger/telegram-login-ios",
			"version": "1.0.0",
			"commit": "f45a597b20956c36b71ea60b8886aff2ee16be84"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@types/node": "^24.0.0",
		"cross-env": "^10.1.0",
		"expo": "^57.0.7",
		"expo-module-scripts": "^56.0.3",
		"lefthook": "^2.1.10",
		"typescript": "~6.0.3"
	},
	"peerDependencies": {
		"expo": "*",
		"react": "*",
		"react-native": "*"
	}
}
